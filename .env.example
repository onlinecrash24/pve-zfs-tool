# Copy to .env and fill in your values. docker-compose.yml reads from .env
# automatically.

# Required only if you want the optional monitoring stack
# (docker compose --profile monitoring up -d). Generate with:
#   openssl rand -hex 32
PROMETHEUS_TOKEN=

# Grafana admin credentials. Override at least the password.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
